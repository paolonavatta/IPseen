@echo off
setlocal EnableDelayedExpansion

set "version=0.07"

:: Check for argument
set "arg=%~1"

:: Get private IPv4 (first one)
for /f "tokens=2 delims=:" %%A in ('ipconfig ^| findstr /R "IPv4.*"') do (
    set "private_ipv4=%%A"
    set "private_ipv4=!private_ipv4:~1!"
    goto :next1
)
:next1

:: Get private IPv6 (first global)
for /f "tokens=2 delims=:" %%A in ('ipconfig ^| findstr /R "IPv6.*"') do (
    set "private_ipv6=%%A"
    set "private_ipv6=!private_ipv6:~1!"
    goto :next2
)
:next2

:: Get MAC address (first active adapter)
for /f "tokens=1,* delims=:" %%A in ('getmac /v /fo list ^| findstr /I "Physical Address"') do (
    set "mac=%%B"
    set "mac=!mac:~1!"
    goto :next3
)
:next3

:: Public IPs via curl (if installed)
set "curl_installed="
where curl >nul 2>nul && set "curl_installed=1"

if "%arg%"=="--help" (
    echo IPseen - Show Private, Public and MAC Addresses
    echo.
    echo Usage:
    echo    IPseen --help       Show this help message
    echo    IPseen --version    Show version
    echo    IPseen --private    Show private IPv4 and IPv6
    echo    IPseen --public     Show public IPv4 and IPv6 (requires curl)
    echo    IPseen --mac        Show MAC address
    echo.
    goto :eof
)

if "%arg%"=="--version" (
    echo IPseen %version%
    goto :eof
)

if "%arg%"=="--mac" (
    echo MAC Address: %mac%
    goto :eof
)

if "%arg%"=="--private" (
    echo Private IPv4 Address: %private_ipv4%
    echo Private IPv6 Address: %private_ipv6%
    goto :eof
)

if "%arg%"=="--public" (
    if not defined curl_installed (
        echo Error: curl not found. Please install curl or use Windows 10+ where it is included.
        goto :eof
    )
    for /f %%A in ('curl -s https://ipinfo.io/ip') do set "public_ipv4=%%A"
    for /f %%A in ('curl -s https://ifconfig.co/ip') do set "public_ipv6=%%A"
    echo Public IPv4 Address: %public_ipv4%
    echo Public IPv6 Address: %public_ipv6%
    goto :eof
)

:: Default: show all
echo Private IPv4 Address: %private_ipv4%
echo Private IPv6 Address: %private_ipv6%

if defined curl_installed (
    for /f %%A in ('curl -s https://ipinfo.io/ip') do set "public_ipv4=%%A"
    for /f %%A in ('curl -s https://ifconfig.co/ip') do set "public_ipv6=%%A"
    echo Public IPv4 Address: %public_ipv4%
    echo Public IPv6 Address: %public_ipv6%
) else (
    echo Public IP: curl not installed.
)

echo MAC Address: %mac%
